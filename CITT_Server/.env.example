# ============================================
# CITT Server Configuration
# ============================================

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=citt_users
DB_PASSWORD=your_password_here
DB_NAME=citt_db
DB_SSL=false

# Server
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (for token blacklist and caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Firebase Admin SDK (for OAuth)
# Set this to the path of your Firebase service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# SMTP / Email (Nodemailer)
# Development: leave SMTP_HOST blank to use local MailHog/Mailpit on :1025
# Production: configure real SMTP settings below
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@citt.ac.tz

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# ClamAV (optional virus scanning for uploads)
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Logging
LOG_LEVEL=debug

# Docker / Production overrides
# Uncomment and set these when deploying with docker-compose
# DB_HOST=postgres
# REDIS_URL=redis://redis:6379
# NODE_ENV=production
