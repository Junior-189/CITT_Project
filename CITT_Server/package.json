{
  "name": "citt_server",
  "version": "1.1.0",
  "description": "CITT - Centre for Innovation and Technology Transfer - Production Server",
  "main": "server.js",
  "scripts": {
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "migrate": "node scripts/run_migrations.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\""
  },
  "keywords": [
    "citt",
    "innovation",
    "technology-transfer",
    "must"
  ],
  "author": "MUST CITT",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "express-slow-down": "^3.1.0",
    "express-validator": "^7.3.2",
    "firebase-admin": "^10.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.16.3",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
